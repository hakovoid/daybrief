---
const base = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden">
  <!-- Background glow: radial gradients + blur -->
  <div class="hero-bg-glow"></div>

  <div class="relative max-w-4xl mx-auto px-4 md:px-6 pt-20 pb-16 md:pt-36 md:pb-32 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.05] border border-white/[0.1] text-db-blue text-xs font-semibold mb-8">
      <span class="w-2 h-2 rounded-full bg-db-blue"></span>
      Open source &middot; Self-hosted
    </div>

    <!-- Headline -->
    <h1 class="text-4xl md:text-[5rem] font-extrabold tracking-[-0.03em] leading-[1.1] mb-6">
      Stop scrolling feeds.<br class="hidden sm:block" />
      <span class="hero-text-gradient">Let AI read for you.</span>
    </h1>

    <!-- Sub -->
    <p class="text-base md:text-xl text-db-text-secondary leading-relaxed max-w-2xl mx-auto mb-10">
      DayBrief monitors your RSS feeds, YouTube channels, and podcasts overnight. Every morning, Gemini AI delivers a concise newsletter with only what matters. Set it up once on GitHub Actions — no server to manage.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <a
        href="https://github.com/yoanbernabeu/daybrief"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 bg-db-blue text-white px-7 py-3.5 rounded-[10px] text-sm font-semibold transition-all hover:bg-db-blue-hover hover:shadow-[0_0_20px_rgba(37,99,235,0.4)]"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Get Started
      </a>
      <a
        href={`${base}/admin/`}
        class="inline-flex items-center justify-center gap-2.5 text-db-text border border-white/[0.15] px-7 py-3.5 rounded-[10px] text-sm font-semibold transition-all hover:bg-white/[0.05] hover:border-white/[0.3]"
      >
        Open Dashboard
        <svg class="w-5 h-5 text-db-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Social proof hint -->
    <p class="mt-8 text-xs text-db-text-muted">
      5 min setup &middot; Open source &middot; Works with any public or private repo
    </p>
  </div>
</section>

<style>
  .hero-bg-glow {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      radial-gradient(circle at 15% 25%, rgba(37, 99, 235, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 85% 30%, rgba(16, 185, 129, 0.12) 0%, transparent 50%),
      radial-gradient(circle at 50% 80%, rgba(245, 158, 11, 0.1) 0%, transparent 60%),
      radial-gradient(circle at 80% 90%, rgba(37, 99, 235, 0.15) 0%, transparent 40%);
    filter: blur(100px);
    opacity: 0.8;
  }

  .hero-text-gradient {
    background: linear-gradient(90deg, #2563eb, #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
